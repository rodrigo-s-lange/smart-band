{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-band.local/contracts/events/events.schema.json",
  "title": "Smart-Band domain events",
  "description": "Catálogo de eventos internos, correspondendo às transições de docs/architecture/domain-model.md. Eventos de negócio (interaction.*, transaction.*, attraction.*) e telemetria técnica (gateway.*) permanecem em namespaces separados (AGENTS.md).",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "transaction_id": {
      "type": "string",
      "description": "8 bytes do protocolo BLE, representados como hex minúsculo (ver contracts/proximity/binary-format.md)",
      "pattern": "^[0-9a-f]{16}$"
    },
    "interaction_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "uint32 atribuído pelo servidor (ADR 0004)"
    },
    "gateway_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "attraction_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "money_minor_units": {
      "type": "integer",
      "minimum": 0,
      "description": "valor em unidade mínima da moeda (ex.: centavos)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "horário do servidor, sempre UTC"
    },
    "envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "version", "occurred_at", "correlation_id", "payload"],
      "properties": {
        "event_id": { "$ref": "#/$defs/uuid" },
        "event_type": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "occurred_at": { "$ref": "#/$defs/timestamp" },
        "correlation_id": {
          "$ref": "#/$defs/uuid",
          "description": "estável para todos os eventos de uma mesma interaction_request/transaction_intent"
        },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "interaction.discovered": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.discovered" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "display_code", "first_gateway_id", "rssi", "expires_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "display_code": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{3}-[0-9A-HJKMNP-TV-Z]{3}$" },
            "first_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "rssi": { "type": "integer" },
            "expires_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.queued": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.queued" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "display_code", "queued_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "display_code": { "type": "string" },
            "queued_at": { "$ref": "#/$defs/timestamp" },
            "withheld_for_duplicate_of": {
              "description": "interaction_id que está bloqueando a publicação por colisão de display_code (ADR 0004); ausente quando não há colisão",
              "$ref": "#/$defs/interaction_id"
            }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.claimed": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.claimed" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "transaction_id", "operator_gateway_id", "attraction_id", "claimed_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "operator_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "attraction_id": { "$ref": "#/$defs/attraction_id" },
            "claimed_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.confirmation_requested": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.confirmation_requested" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "transaction_id", "radio_gateway_id", "attempt", "requested_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "radio_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "attempt": { "type": "integer", "minimum": 1, "maximum": 3, "description": "ADR 0003: até 3 tentativas de lease" },
            "requested_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.confirmed": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.confirmed" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "transaction_id", "confirmed_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "confirmed_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.confirmation_timeout": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.confirmation_timeout" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "transaction_id", "timed_out_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "timed_out_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.cancelled": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.cancelled" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "cancelled_by_operator_gateway_id", "stage", "cancelled_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "transaction_id": {
              "description": "presente apenas se já havia claim (stage claimed/awaiting_confirmation)",
              "$ref": "#/$defs/transaction_id"
            },
            "cancelled_by_operator_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "stage": { "type": "string", "enum": ["queued", "claimed", "awaiting_confirmation"] },
            "cancelled_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "interaction.expired": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "interaction.expired" },
        "payload": {
          "type": "object",
          "required": ["interaction_id", "stage", "expired_at"],
          "properties": {
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "stage": { "type": "string", "enum": ["discovered", "queued", "claimed"] },
            "expired_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "transaction.denied": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "transaction.denied" },
        "payload": {
          "type": "object",
          "required": ["transaction_id", "interaction_id", "reason", "denied_at"],
          "properties": {
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "reason": { "type": "string", "enum": ["insufficient_balance", "rule_violation"] },
            "denied_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "transaction.authorized": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "transaction.authorized" },
        "payload": {
          "type": "object",
          "required": ["transaction_id", "interaction_id", "attraction_id", "amount", "ledger_entry_id", "authorized_at"],
          "properties": {
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "attraction_id": { "$ref": "#/$defs/attraction_id" },
            "amount": { "$ref": "#/$defs/money_minor_units" },
            "ledger_entry_id": { "$ref": "#/$defs/uuid" },
            "authorized_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "transaction.completed": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "transaction.completed" },
        "payload": {
          "type": "object",
          "required": ["transaction_id", "interaction_id", "attraction_id", "remaining_balance", "actuation", "completed_at"],
          "properties": {
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "attraction_id": { "$ref": "#/$defs/attraction_id" },
            "remaining_balance": { "$ref": "#/$defs/money_minor_units" },
            "actuation": { "type": "string", "enum": ["automatic", "manual_override"] },
            "completed_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "attraction.actuation_failed": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "attraction.actuation_failed" },
        "payload": {
          "type": "object",
          "required": ["transaction_id", "interaction_id", "attraction_id", "operator_gateway_id", "failed_at"],
          "properties": {
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "attraction_id": { "$ref": "#/$defs/attraction_id" },
            "operator_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "failed_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false
        }
      }
    },

    "transaction.actuation_override": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "transaction.actuation_override" },
        "payload": {
          "type": "object",
          "required": ["transaction_id", "interaction_id", "operator_gateway_id", "overridden_at"],
          "properties": {
            "transaction_id": { "$ref": "#/$defs/transaction_id" },
            "interaction_id": { "$ref": "#/$defs/interaction_id" },
            "operator_gateway_id": { "$ref": "#/$defs/gateway_id" },
            "overridden_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false,
          "description": "auditoria de override manual (ADR 0003); base para detectar padrão anômalo de overrides por gateway"
        }
      }
    },

    "gateway.status_changed": {
      "allOf": [{ "$ref": "#/$defs/envelope" }],
      "properties": {
        "event_type": { "const": "gateway.status_changed" },
        "payload": {
          "type": "object",
          "required": ["gateway_id", "status", "changed_at"],
          "properties": {
            "gateway_id": { "$ref": "#/$defs/gateway_id" },
            "status": { "type": "string", "enum": ["online", "offline", "degraded"] },
            "changed_at": { "$ref": "#/$defs/timestamp" }
          },
          "additionalProperties": false,
          "description": "telemetria técnica — nunca mistura com eventos de ledger (AGENTS.md)"
        }
      }
    }
  },

  "oneOf": [
    { "$ref": "#/$defs/interaction.discovered" },
    { "$ref": "#/$defs/interaction.queued" },
    { "$ref": "#/$defs/interaction.claimed" },
    { "$ref": "#/$defs/interaction.confirmation_requested" },
    { "$ref": "#/$defs/interaction.confirmed" },
    { "$ref": "#/$defs/interaction.confirmation_timeout" },
    { "$ref": "#/$defs/interaction.cancelled" },
    { "$ref": "#/$defs/interaction.expired" },
    { "$ref": "#/$defs/transaction.denied" },
    { "$ref": "#/$defs/transaction.authorized" },
    { "$ref": "#/$defs/transaction.completed" },
    { "$ref": "#/$defs/attraction.actuation_failed" },
    { "$ref": "#/$defs/transaction.actuation_override" },
    { "$ref": "#/$defs/gateway.status_changed" }
  ]
}
